{
  "name": "sge-spa-insurance",
  "version": "1.0.0",
  "private": true,
  "homepage": "insurance",
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@emotion/jest": "11.10.8",
    "@emotion/react": "11.10.4",
    "@emotion/styled": "11.10.4",
    "@mui/material": "^5.12.3",
    "@pichincha/encrypt-microsite": "1.0.6",
    "@pichincha/events-microsite": "1.0.40",
    "@reduxjs/toolkit": "^2.7.0",
    "@tanstack/react-query": "^4.6.1",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^14.3.0",
    "@types/node-forge": "1.3.2",
    "@types/redux-logger": "^3.0.13",
    "axios": "0.27.2",
    "axios-mock-adapter": "^1.21.1",
    "clsx": "1.2.1",
    "env-cmd": "^10.1.0",
    "jest-canvas-mock": "2.5.0",
    "lodash.get": "4.4.2",
    "lottie-react": "^2.3.1",
    "node-forge": "1.3.1",
    "react": "^18.2.0",
    "react-circular-progressbar": "^2.1.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "6.14.2",
    "react-scripts": "5.0.1",
    "redux-logger": "^3.0.6",
    "ts-jest": "28.0.7",
    "web-vitals": "2.1.4"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@types/jest": "^28.1.6",
    "@types/node": "^18.6.1",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "5.35.1",
    "@typescript-eslint/parser": "5.35.1",
    "eslint": "8.41.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jest": "26.6.0",
    "eslint-plugin-jsx-a11y": "6.6.1",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "prettier": "2.7.1",
    "sass": "1.54.5",
    "typescript": "4.7.4"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint-fix": "eslint \"src/**/*.{ts,tsx}\" --quiet --fix",
    "start": "craco start",
    "start:local": "env-cmd -f .env.local craco start",
    "start:development": "env-cmd -f .env.development craco start",
    "start:staging": "env-cmd -f .env.staging craco start",
    "start:production": "env-cmd -f .env.production craco start",
    "build": "env-cmd -f .env.local craco build",
    "build:local": "env-cmd -f .env.local craco build",
    "build:development": "env-cmd -f .env.development craco build && mkdir -p build/insurance/static && mv build/static/* build/insurance/static && rm -Rf build/static",
    "build:staging": "env-cmd -f .env.staging craco build && mkdir -p build/insurance/static && mv build/static/* build/insurance/static && rm -Rf build/static",
    "build:production": "env-cmd -f .env.production craco build && mkdir -p build/insurance/static && mv build/static/* build/insurance/static && rm -Rf build/static",
    "test": "craco test",
    "eject": "craco eject",
    "coverage": "craco test --coverage --watchAll=false"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/assets/",
      "<rootDir>/src/index.tsx",
      "<rootDir>/src/reportWebVitals.ts",
      "<rootDir>/src/__tests__/",
      "<rootDir>/src/graphql/",
      "<rootDir>/src/*.{test,spec}.{js,jsx,ts,tsx}",
      "<rootDir>/src/*.interface.{ts,tsx}"
    ],
    "moduleNameMapper": {
      "\\.(jpg|ico|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/src/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/src/__mocks__/fileMock.js",
      "@app/(.*)$": "<rootDir>/src/$1"
    }
  }
}
